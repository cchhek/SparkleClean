# Server Port
PORT=5000

# PostgreSQL Connection String (Supabase Connection String - Transaction pooler recommended)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-DATABASE-URL].supabase.co:5432/postgres?schema=public"

# JWT Token Secret
JWT_SECRET="generate_a_very_long_random_string_here_for_security"

# Frontend URL (For CORS and Redirects)
FRONTEND_URL="http://localhost:5173"

# Stripe Secrets (Leave blank or default to use simulated payment mode)
STRIPE_SECRET_KEY="your_stripe_secret_key"

# SMTP Email Configuration (Leave blank to output emails to the console instead)
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="your_smtp_username"
EMAIL_PASS="your_smtp_password"
EMAIL_SECURE=false
EMAIL_FROM='"Sparkle Cleaning" <bookings@sparklecleaning.com>'
